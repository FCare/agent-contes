# LLM (même endpoint self-hosted que agent-news)
LLM_BASE_URL=http://thebrain:8000/v1
LLM_MODEL=gemma-4-12b-it
LLAMACPP_API_KEY=your_llamacpp_key_here

# Agent MQTT (Voight-Kampff) — mêmes valeurs que les autres agents (agent-news, agent-weather)
VK_URL=http://voight-kampff:8080
MQTT_HOST=mosquitto-broker
MQTT_PORT=1883
MQTT_SERVICE_USERNAME=admin
MQTT_SERVICE_API_KEY=your_mqtt_service_api_key_here

# Racine des contes montée dans le conteneur (voir docker-compose.yml)
CONTES_ROOT=/contes

# Découpage des mini-résumés (secondes)
PERIOD_SECONDS=180

# Désactive les vérifications de mise à jour HuggingFace (à activer après premier téléchargement des modèles)
HF_HUB_OFFLINE=1

# Requis à partir de l'étape "transcribe" (diarization pyannote, modèle protégé)
HF_TOKEN=your_hf_token_here
